rules_version = '2';

// Deployed via Firebase Console — deploy updates with: firebase deploy --only firestore:rules
service cloud.firestore {
  match /databases/{database}/documents {

    // Users collection — authenticated users can manage their own doc
    match /users/{userId} {
      allow read, create, update: if request.auth != null && request.auth.uid == userId;

      // Journal subcollection
      match /journal/{entryId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Trades collection — users can CRUD their own trades
    match /trades/{tradeId} {
      allow read, update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
    }

    // Journal entries collection — users can CRUD their own entries
    match /journalEntries/{entryId} {
      allow read, update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
    }

    // Admin collection — only readable via Console
    match /admin/{docId} {
      allow read, write: if false;
    }
  }
}
